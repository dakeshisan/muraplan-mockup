# ATLAS · Снабжение — конфигурация фермы. Значения выдаёт PM.
# НЕ коммитить реальные токены/вебхуки. Скопировать в .env, заполнить.
TELEGRAM_TOKEN_MURAVEY=
TELEGRAM_TOKEN_KEEPER=
BITRIX_WEBHOOK=
DB_PATH=supply.sqlite3
DRY_RUN=1

# Онлайн-доступ (HTTP Basic Auth). Задать ATLAS_PASS → сервер требует логин/пароль
# (для туннеля/VPS). Пусто → локальный режим без пароля. Логин по умолчанию atlas.
ATLAS_USER=atlas
ATLAS_PASS=
