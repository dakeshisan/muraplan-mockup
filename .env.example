# Internal PostgreSQL instance. Keep the real value only in the VPS secret store.
ATLAS_DATABASE_URL=postgres://atlas:<replace-me>@127.0.0.1:5432/atlas

# Authentik or another approved corporate SSO entry point.
ATLAS_SSO_LOGIN_URL=https://auth.atamura.group/application/o/authorize/

# At least 32 random characters. Shared only by the Sherlock and 1C exporters.
ATLAS_INGEST_HMAC_SECRET=<replace-with-random-secret>
