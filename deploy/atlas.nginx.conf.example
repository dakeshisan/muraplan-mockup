# Template only. Validate and adapt on the corporate VPS during the production audit.
# The application must listen on loopback only; never expose its port directly.
upstream atlas_app {
  server 127.0.0.1:3100;
  keepalive 16;
}

server {
  listen 443 ssl http2;
  server_name atlas.atamura.group;

  # TLS certificates and Authentik outpost values are installed outside git.
  location /outpost.goauthentik.io/ {
    proxy_pass http://127.0.0.1:9000/outpost.goauthentik.io/;
    proxy_set_header Host $host;
    proxy_set_header X-Original-URL $scheme://$http_host$request_uri;
  }

  location = /health {
    proxy_pass http://atlas_app;
    proxy_set_header Host $host;
  }

  # Exporters run on the VPS. Network isolation and HMAC are both required.
  location ^~ /api/ingest/ {
    allow 127.0.0.1;
    deny all;
    proxy_pass http://atlas_app;
    proxy_set_header Host $host;
  }

  location / {
    auth_request /outpost.goauthentik.io/auth/nginx;
    error_page 401 = @atlas_signin;
    auth_request_set $atlas_user $upstream_http_x_authentik_username;
    auth_request_set $atlas_name $upstream_http_x_authentik_name;
    # Authentik must populate these two controlled claims from group membership.
    auth_request_set $atlas_roles $upstream_http_x_atlas_roles;
    auth_request_set $atlas_objects $upstream_http_x_atlas_objects;

    proxy_pass http://atlas_app;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Atlas-Authenticated true;
    proxy_set_header X-Atlas-User $atlas_user;
    proxy_set_header X-Atlas-Display-Name $atlas_name;
    proxy_set_header X-Atlas-Roles $atlas_roles;
    proxy_set_header X-Atlas-Objects $atlas_objects;
  }

  location @atlas_signin {
    return 302 /outpost.goauthentik.io/start?rd=$scheme://$http_host$request_uri;
  }
}
